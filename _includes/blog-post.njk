---
layout: blog-base.njk
---

<article class="blog-post">

  <header class="post-header{% if featuredImage %} has-hero-image{% endif %}"{% if featuredImage %} style="--post-hero-img: url('{{ featuredImage }}')"{% endif %}>
    <div class="container">
      <div class="post-header-inner">
        <a href="/blog/" class="back-link">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
          All Posts
        </a>
        <div class="post-meta">
          {% if category %}<span class="post-category-badge">{{ category | categoryLabel }}</span>{% endif %}
          <time class="post-date" datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
          {% if author %}<span class="post-author">{{ author }}</span>{% endif %}
        </div>
        <h1 class="post-title">{{ title }}</h1>
        {% if excerpt %}<p class="post-excerpt-lead">{{ excerpt }}</p>{% endif %}

        <a href="#post-media-widget" class="post-listen-anchor">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
          Listen to this post
        </a>

        <!-- Share — top -->
        <div class="post-share post-share--header">
          <span class="post-share-label">Share</span>
          <a class="share-btn share-x" data-share-x href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on X">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.743l7.73-8.835L1.254 2.25H8.08l4.26 5.632 5.905-5.632Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a class="share-btn share-facebook" data-share-facebook href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span class="share-label">Facebook</span>
          </a>
          <a class="share-btn share-whatsapp" data-share-whatsapp href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span class="share-label">WhatsApp</span>
          </a>
          <div class="share-group">
            <button class="share-btn share-copy share-instagram-icon" data-share-copy aria-label="Copy for Instagram">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </button>
            <button class="share-btn share-copy" data-share-copy aria-label="Copy link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <span class="share-label">Copy link</span>
            </button>
          </div>
          <span class="share-copy-feedback" data-share-feedback aria-live="polite" hidden></span>
        </div>
      </div>
    </div>
  </header>

  {% set related = collections.post | relatedPosts(page.url, category, postTags, 4) %}
  <div class="post-body{% if featuredImage %} has-featured-image{% endif %}">

    {% if featuredImage %}
    <div class="post-featured-image">
      <img src="{{ featuredImage }}" alt="{{ title }}" loading="eager"
        onerror="(function(img){var r=0;(function a(){if(r>=3)return;r++;setTimeout(function(){img.src=img.src.split('?')[0]+'?r='+r;img.addEventListener('load',function(){img.classList.add('img-loaded');},{once:true});img.addEventListener('error',a,{once:true});},6000*r);})();})(this)">
    </div>
    {% endif %}
    <div class="container">
      <div class="post-layout has-sidebar">
        <div class="post-main">

          <div class="prose">
            {{ content | safe }}
          </div>

          {% if references %}
          <div class="post-references">
            <h2 class="references-heading">References &amp; Further Reading</h2>
            <div class="post-references-body">
              <div class="prose prose-references">
                {{ references | markdownify | safe }}
              </div>
            </div>
            <button class="post-references-toggle" aria-expanded="false">
              <span class="references-toggle-label">Show all references</span>
              <svg class="references-toggle-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
          {% endif %}

          {% if postTags and postTags.length %}
          <div class="post-tags">
            <span class="post-tags-label">Tags</span>
            {% for tag in postTags %}
            <span class="post-tag">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}

          <!-- Share — bottom -->
          <div class="post-share post-share--footer">
        <span class="post-share-label">Share this post</span>
        <a class="share-btn share-x" data-share-x href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on X">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.743l7.73-8.835L1.254 2.25H8.08l4.26 5.632 5.905-5.632Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a class="share-btn share-facebook" data-share-facebook href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Facebook
        </a>
        <a class="share-btn share-whatsapp" data-share-whatsapp href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <div class="share-group">
          <button class="share-btn share-copy share-instagram-icon" data-share-copy aria-label="Copy for Instagram">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </button>
          <button class="share-btn share-copy" data-share-copy aria-label="Copy link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            Copy link
          </button>
        </div>
        <span class="share-copy-feedback" data-share-feedback aria-live="polite" hidden></span>
      </div>

          <div class="post-footer">
            <a href="/blog/" class="back-link">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
              Back to all posts
            </a>
          </div>

        </div>{# end .post-main #}

        <aside class="post-sidebar">
          <div class="post-sidebar-sticky">

            <!-- Listen / Watch widget -->
            <div class="post-media-widget" id="post-media-widget">
              <div class="media-tabs" role="tablist">
                <button class="media-tab is-active" role="tab" aria-selected="true" data-media-tab="listen">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                  Listen
                </button>
                <button class="media-tab" role="tab" aria-selected="false" data-media-tab="watch">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  Watch
                </button>
              </div>

              <div class="media-panel" data-media-panel="listen">
                {% if audioTracks and audioTracks.length %}
                  {% if audioTracks.length == 1 %}
                  <audio controls class="media-audio-player" src="{{ audioTracks[0] }}"></audio>
                  {% else %}
                  <div class="audio-playlist">
                    <div class="audio-track-btns">
                      {% for track in audioTracks %}
                      <button class="audio-track-btn{% if loop.first %} is-active{% endif %}" data-track-src="{{ track }}">
                        Track {{ loop.index }}
                      </button>
                      {% endfor %}
                    </div>
                    <audio controls class="media-audio-player" src="{{ audioTracks[0] }}"></audio>
                  </div>
                  {% endif %}
                {% else %}
                <div class="media-coming-soon">
                  <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                  <p>Audio version</p>
                  <span class="media-soon-badge">Coming soon</span>
                </div>
                {% endif %}
              </div>

              <div class="media-panel{% if youtubeId %} media-panel--video{% endif %} is-hidden" data-media-panel="watch">
                {% if youtubeId %}
                <div class="youtube-embed">
                  <iframe src="https://www.youtube-nocookie.com/embed/{{ youtubeId }}" title="{{ title }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
                </div>
                {% else %}
                <div class="media-coming-soon">
                  <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  <p>Video version</p>
                  <span class="media-soon-badge">Coming soon</span>
                </div>
                {% endif %}
              </div>
            </div>{# end .post-media-widget #}

            {% if related and related.length %}
            <h3 class="sidebar-heading">Down the rabbit hole</h3>
            {% for post in related %}
            <a href="{{ post.url }}" class="rabbit-card">
              {% if post.data.featuredImage %}
              <img src="{{ post.data.featuredImage }}" alt="" class="rabbit-card-thumb" loading="lazy">
              {% else %}
              <div class="rabbit-card-thumb rabbit-card-thumb--fallback"></div>
              {% endif %}
              <div class="rabbit-card-info">
                <span class="rabbit-card-title">{{ post.data.title }}</span>
                <time class="rabbit-card-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
              </div>
            </a>
            {% endfor %}
            {% endif %}

          </div>
        </aside>

      </div>{# end .post-layout #}
    </div>{# end .container #}
  </div>{# end .post-body #}

  <script>
  // Fade in featured image and sidebar thumbnails once loaded.
  (function () {
    document.querySelectorAll('.post-featured-image img, .rabbit-card-thumb').forEach(function (img) {
      if (img.complete && img.naturalWidth) {
        img.classList.add('img-loaded');
      } else {
        img.addEventListener('load', function () { img.classList.add('img-loaded'); }, { once: true });
      }
    });
  })();
  </script>

  <script>
  // Wrap each table in .prose with a .table-wrapper div so border-radius
  // and overflow: hidden clip the corners correctly. Also pulls any
  // preceding .table-caption paragraph into the wrapper.
  (function () {
    document.querySelectorAll('.prose table').forEach(function (table) {
      var prev = table.previousElementSibling;
      var wrapper = document.createElement('div');
      wrapper.className = 'table-wrapper';
      table.parentNode.insertBefore(wrapper, table);
      wrapper.appendChild(table);
      if (prev && prev.classList.contains('table-caption')) {
        wrapper.insertBefore(prev, table);
      }
    });
  })();
  </script>

  <script>
  (function () {
    var url = window.location.href;
    var titleEl = document.querySelector('.post-title');
    var title = titleEl ? titleEl.textContent.trim() : document.title;

    // Set share URLs on all instances
    document.querySelectorAll('[data-share-x]').forEach(function (el) {
      el.href = 'https://twitter.com/intent/tweet?url=' + encodeURIComponent(url) + '&text=' + encodeURIComponent(title);
    });

    document.querySelectorAll('[data-share-facebook]').forEach(function (el) {
      el.href = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url);
    });

    document.querySelectorAll('[data-share-whatsapp]').forEach(function (el) {
      el.href = 'https://wa.me/?text=' + encodeURIComponent(title + ' — ' + url);
    });

    // Copy link — each button finds its own feedback span
    document.querySelectorAll('[data-share-copy]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var feedback = btn.closest('.post-share').querySelector('[data-share-feedback]');

        function showFeedback() {
          if (feedback) {
            feedback.textContent = '✓ Copied!';
            feedback.removeAttribute('hidden');
            setTimeout(function () {
              feedback.setAttribute('hidden', '');
              feedback.textContent = '';
            }, 2500);
          }
        }

        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(showFeedback);
        } else {
          var ta = document.createElement('textarea');
          ta.value = url;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          showFeedback();
        }
      });
    });
  })();
  </script>

  <script>
  // References — expand / collapse
  (function () {
    var section = document.querySelector('.post-references');
    var body    = section && section.querySelector('.post-references-body');
    var btn     = section && section.querySelector('.post-references-toggle');
    var label   = btn && btn.querySelector('.references-toggle-label');
    if (!section || !body || !btn) return;

    btn.addEventListener('click', function () {
      var expanded = section.classList.contains('is-expanded');
      if (expanded) {
        // Collapse: pin height first, then shrink next frame
        body.style.maxHeight = body.scrollHeight + 'px';
        requestAnimationFrame(function () {
          body.style.maxHeight = '10rem';
        });
        section.classList.remove('is-expanded');
        btn.setAttribute('aria-expanded', 'false');
        label.textContent = 'Show all references';
      } else {
        // Expand: animate to full height, then release to none so it can reflow
        body.style.maxHeight = body.scrollHeight + 'px';
        body.addEventListener('transitionend', function release() {
          body.style.maxHeight = 'none';
          body.removeEventListener('transitionend', release);
        });
        section.classList.add('is-expanded');
        btn.setAttribute('aria-expanded', 'true');
        label.textContent = 'Show fewer';
      }
    });
  })();
  </script>

  <script>window._mcjCrumbs = [{ label: 'Home', href: '/' }, { label: 'Essays', href: '/blog/' }, { label: {{ title | dump | safe }} }];</script>

  <script>
  // Media widget — Listen / Watch tab switching
  (function () {
    var widget = document.querySelector('.post-media-widget');
    if (!widget) return;
    widget.querySelectorAll('.media-tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        var target = tab.dataset.mediaTab;
        widget.querySelectorAll('.media-tab').forEach(function (t) {
          t.classList.toggle('is-active', t === tab);
          t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
        });
        widget.querySelectorAll('.media-panel').forEach(function (panel) {
          panel.classList.toggle('is-hidden', panel.dataset.mediaPanel !== target);
        });
      });
    });

    // Audio playlist — track selector
    widget.querySelectorAll('.audio-track-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var playlist = btn.closest('.audio-playlist');
        var audio = playlist.querySelector('.media-audio-player');
        playlist.querySelectorAll('.audio-track-btn').forEach(function (b) {
          b.classList.toggle('is-active', b === btn);
        });
        audio.src = btn.dataset.trackSrc;
        audio.play();
      });
    });

    // Stop site music whenever any blog audio starts (track button or native controls)
    widget.querySelectorAll('.media-audio-player').forEach(function (a) {
      a.addEventListener('play', function () {
        if (window._mcjPauseSiteMusic) window._mcjPauseSiteMusic();
      });
    });
  })();
  </script>

