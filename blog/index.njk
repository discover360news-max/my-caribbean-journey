---
layout: blog-base.njk
title: Blog
description: Stories, history, and dispatches from the Caribbean islands — written by Quincy.
permalink: /blog/
---

{% set posts = collections.post %}

<section class="blog-hero">
  <div class="container">
    <p class="section-label">Stories & Culture</p>
    <h1 class="section-title">The <span class="text-gold">Blog</span></h1>
    <p class="blog-intro">Stories, history, and dispatches from the islands — written by Quincy.</p>
  </div>
</section>

<script>
// Word pool baked in at build time from post titles + tags.
// Regenerates automatically on every deploy (including new posts).
(function () {
  var isMobile = window.innerWidth < 768;

  var raw = [
    {%- for post in posts -%}
      {%- for word in post.data.title.split(' ') -%}
        {{ word | replace('"', '') | replace("'", '') | trim | dump | safe }},
      {%- endfor -%}
      {%- if post.data.postTags -%}
        {%- for tag in post.data.postTags -%}
          {{ tag | dump | safe }},
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}
  ];

  // Deduplicate, strip short/empty words and common stop words
  var STOP = ['the','a','an','and','or','of','in','on','at','to','is','it','by','for','with','as','was','be','from','this','that','are','were','have','has','had','but','not','so','its'];
  var words = [];
  raw.forEach(function (w) {
    if (!w || w.length < 3) return;
    if (STOP.indexOf(w.toLowerCase()) !== -1) return;
    if (words.indexOf(w) === -1) words.push(w);
  });

  if (words.length < 4) return;

  var hero   = document.querySelector('.blog-hero');
  var SLOTS  = isMobile ? 6 : 10;   // fewer concurrent words on mobile
  var SPEED  = [70, 130];
  var HOLD   = [2500, 5000];
  var FADE   = 700;

  function rand(a, b)    { return Math.random() * (b - a) + a; }
  function randInt(a, b) { return Math.floor(rand(a, b)); }
  function pick()        { return words[randInt(0, words.length)]; }

  function run(el, delay) {
    setTimeout(function () {
      // On mobile text is centred so spread words across the full width
      el.style.left      = isMobile ? rand(5, 88) + '%' : rand(42, 88) + '%';
      el.style.top       = rand(12, 78) + '%';
      el.style.fontSize  = isMobile ? rand(0.55, 0.85) + 'rem' : rand(0.7, 1.15) + 'rem';
      el.style.transform = 'rotate(' + rand(-10, 10) + 'deg)';
      el.style.opacity   = rand(0.12, 0.22);
      el.textContent     = '';

      var word  = pick();
      var i     = 0;
      var speed = randInt(SPEED[0], SPEED[1]);

      function type() {
        if (i < word.length) {
          el.textContent += word[i++];
          setTimeout(type, speed);
        } else {
          // Hold, then fade out and restart
          setTimeout(function () {
            el.style.transition = 'opacity ' + FADE + 'ms ease';
            el.style.opacity    = 0;
            setTimeout(function () {
              el.style.transition = '';
              run(el, 0);
            }, FADE + 50);
          }, randInt(HOLD[0], HOLD[1]));
        }
      }

      type();
    }, delay);
  }

  for (var s = 0; s < SLOTS; s++) {
    var el = document.createElement('span');
    el.className = 'blog-hero-word';
    hero.appendChild(el);
    run(el, s * 350 + randInt(0, 200));
  }
}());
</script>

<section class="blog-posts">
  <div class="container">

    {% if posts.length %}
    <a href="#filters" class="filter-pill" id="filter-pill-link" hidden>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="4" y1="21" y2="14"/><line x1="4" x2="4" y1="10" y2="3"/><line x1="12" x2="12" y1="21" y2="12"/><line x1="12" x2="12" y1="8" y2="3"/><line x1="20" x2="20" y1="21" y2="16"/><line x1="20" x2="20" y1="12" y2="3"/><line x1="1" x2="7" y1="14" y2="14"/><line x1="9" x2="15" y1="12" y2="12"/><line x1="17" x2="23" y1="16" y2="16"/></svg>
      Filter
    </a>
    <div class="post-grid" id="post-grid">
      {% for post in posts %}
      <article class="post-card{% if loop.first or post.data.featured %} is-featured{% endif %}"
        data-category="{{ post.data.category or '' }}"
        data-tags="{{ post.data.postTags | join(' ') if post.data.postTags else '' }}">
        <a href="{{ post.url }}" class="post-card-image" aria-label="{{ post.data.title }}">
          {% if post.data.featuredImage %}
          {% if loop.first %}
          <img src="{{ post.data.featuredImage }}" alt="" loading="eager" fetchpriority="high">
          {% else %}
          <img src="{{ post.data.featuredImage }}" alt="" loading="lazy">
          {% endif %}
          {% endif %}
          {% if loop.first %}<span class="post-new-badge">New</span>{% endif %}
          <div class="post-card-overlay">
            <h2 class="post-card-title">{{ post.data.title }}</h2>
            {% if post.data.excerpt %}<p class="post-excerpt">{{ post.data.excerpt | truncateWords(20) }}</p>{% endif %}
          </div>
        </a>
        <div class="post-card-body">
          {% if post.data.category %}<span class="post-category-badge">{{ post.data.category | categoryLabel }}</span>{% endif %}
          <div class="post-card-foot">
            <time class="post-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
            <a href="{{ post.url }}" class="post-link">
              Dive in
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    <span id="filters" class="filter-anchor"></span>
    <div class="post-filters" id="post-filters" hidden>
      <div class="filter-chips" id="filter-chips"></div>
    </div>

    {% else %}
    <p class="no-posts">No posts yet. Check back soon.</p>
    {% endif %}

  </div>
</section>

<script>
// Fade in card images once loaded (prevents hard pop-in).
// Also handles already-cached images that fire no load event.
(function () {
  document.querySelectorAll('.post-card-image img').forEach(function (img) {
    if (img.complete && img.naturalWidth) {
      img.classList.add('img-loaded');
    } else {
      img.addEventListener('load', function () { img.classList.add('img-loaded'); }, { once: true });
    }
  });
})();

// Retry featured images that 404 on load (CDN propagation delay on new posts).
// Hides the broken container immediately, then re-attempts with a cache-bust
// param every 6 seconds, up to 3 times (~18s window covers most deploys).
(function () {
  document.querySelectorAll('.post-card-image img').forEach(function (img) {
    var retries = 0;
    img.addEventListener('error', function () {
      var el = this;
      var src = el.getAttribute('src').split('?')[0];
      var container = el.closest('.post-card-image');
      if (container) container.style.visibility = 'hidden';
      (function attempt() {
        if (retries >= 3) return;
        retries++;
        setTimeout(function () {
          el.src = src + '?r=' + retries;
          el.addEventListener('load', function () {
            if (container) container.style.visibility = '';
          }, { once: true });
          el.addEventListener('error', attempt, { once: true });
        }, 6000 * retries);
      })();
    });
  });
})();
</script>

<script>
(function () {
  var cards = Array.from(document.querySelectorAll('#post-grid .post-card'));
  if (!cards.length) return;

  var CATEGORY_LABELS = {
    culture: 'Culture & Heritage',
    history: 'History',
    travel:  'Travel & Expat',
    food:    'Food & Traditions',
    music:   'Music & Arts',
    news:    'News & Updates'
  };

  // Collect unique categories and tags from rendered cards
  var categories = [], tags = [];
  cards.forEach(function (card) {
    var cat = card.dataset.category;
    if (cat && categories.indexOf(cat) === -1) categories.push(cat);
    var cardTags = card.dataset.tags ? card.dataset.tags.split(' ').filter(Boolean) : [];
    cardTags.forEach(function (tag) {
      if (tags.indexOf(tag) === -1) tags.push(tag);
    });
  });

  if (!categories.length && !tags.length) return;

  var container = document.getElementById('filter-chips');
  var filterBar  = document.getElementById('post-filters');
  var activeValue = null;
  var activeType  = null;

  function buildChip(value, label, type) {
    var btn = document.createElement('button');
    btn.className = 'filter-chip';
    btn.textContent = label;
    btn.dataset.value = value;
    btn.dataset.type  = type;
    btn.addEventListener('click', function () {
      if (activeValue === value && activeType === type) {
        activeValue = null; activeType = null;
      } else {
        activeValue = value; activeType = type;
      }
      applyFilter();
    });
    return btn;
  }

  function applyFilter() {
    container.querySelectorAll('.filter-chip').forEach(function (btn) {
      btn.classList.toggle('is-active',
        btn.dataset.value === activeValue && btn.dataset.type === activeType);
    });
    cards.forEach(function (card) {
      var show = true;
      if (activeValue) {
        if (activeType === 'category') {
          show = card.dataset.category === activeValue;
        } else {
          var t = card.dataset.tags ? card.dataset.tags.split(' ') : [];
          show = t.indexOf(activeValue) !== -1;
        }
      }
      card.style.display = show ? '' : 'none';
    });
    // Collapse the featured card to regular size when a filter is active
    var featured = document.querySelector('#post-grid .is-featured');
    if (featured) featured.classList.toggle('filter-active', !!activeValue);
  }

  function buildGroup(labelText, chips) {
    var group = document.createElement('div');
    group.className = 'filter-group';
    var lbl = document.createElement('span');
    lbl.className = 'filter-section-label';
    lbl.textContent = labelText;
    group.appendChild(lbl);
    var row = document.createElement('div');
    row.className = 'filter-chip-row';
    chips.forEach(function (chip) { row.appendChild(chip); });
    group.appendChild(row);
    return group;
  }

  // Build category group
  if (categories.length) {
    var catChips = categories.map(function (cat) {
      return buildChip(cat, CATEGORY_LABELS[cat] || cat, 'category');
    });
    container.appendChild(buildGroup('Category', catChips));
  }

  // Divider between groups
  if (categories.length && tags.length) {
    var divider = document.createElement('div');
    divider.className = 'filter-divider';
    container.appendChild(divider);
  }

  // Build tag group
  if (tags.length) {
    var tagChips = tags.map(function (tag) {
      var label = tag.charAt(0).toUpperCase() + tag.slice(1);
      return buildChip(tag, label, 'tag');
    });
    container.appendChild(buildGroup('Tags', tagChips));
  }

  filterBar.removeAttribute('hidden');
  var pill = document.getElementById('filter-pill-link');
  if (pill) {
    pill.removeAttribute('hidden');
    pill.addEventListener('click', function () {
      setTimeout(function () {
        filterBar.classList.remove('is-highlighted');
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            filterBar.classList.add('is-highlighted');
            filterBar.addEventListener('animationend', function () {
              filterBar.classList.remove('is-highlighted');
            }, { once: true });
          });
        });
      }, 450);
    });
  }
})();
</script>
<script>window._mcjCrumbs = [{ label: 'Home', href: '/' }, { label: 'Blog' }];</script>
